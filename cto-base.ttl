###  https://w3id.org/pmd/cto/CTO_0000002
:CTO_0000002 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000006 ;
             rdfs:label "single test piece machine" ;
             skos:definition "Testing machine that permits straining of a single test piece." .


###  https://w3id.org/pmd/cto/CTO_0000005
:CTO_0000005 rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/pmd/tto/TTO_0000033>
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty obo:RO_0000052 ;
                                                          owl:someValuesFrom :CTO_0000008
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf <https://w3id.org/pmd/tto/TTO_0000033> ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000052 ;
                               owl:someValuesFrom :CTO_0000008
                             ] ;
             rdfs:label "percentage elongation after creep fracture"@en ;
             skos:definition "A percentage elongation after creep fracture is a mechanical property that quantifies the relative increase in length of a material after creep fracture, expressed as a percentage." .


###  https://w3id.org/pmd/cto/CTO_0000006
:CTO_0000006 rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( <http://purls.helmholtz-metadaten.de/mwo/MWO_0001023>
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty obo:IAO_0000136 ;
                                                          owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000588>
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001023> ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:IAO_0000136 ;
                               owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000588>
                             ] ;
             rdfs:label "creep test machine type"@en ;
             skos:definition "A creep test machine type is a device type specification that classifies a device according to the type of creep testing machine it is." .


###  https://w3id.org/pmd/cto/CTO_0000007
:CTO_0000007 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000006 ;
             rdfs:label "multiple test piece machine" ;
             skos:definition "Testing machine that permits straining of more than one test piece simultaneously." .


###  https://w3id.org/pmd/cto/CTO_0000008
:CTO_0000008 rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( obo:BFO_0000030
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty obo:RO_0000056 ;
                                                          owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty obo:RO_0000087 ;
                                                          owl:someValuesFrom :CTO_1000010
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf obo:BFO_0000030 ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000056 ;
                               owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000087 ;
                               owl:someValuesFrom :CTO_1000010
                             ] ;
             rdfs:label "creep test piece"@en ;
             skos:definition "A creep test piece is an object that is a material specimen prepared for and subjected to a creep test." .


###  https://w3id.org/pmd/cto/CTO_0000009
:CTO_0000009 rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204>
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty obo:OBI_0000312 ;
                                                          owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204> ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:OBI_0000312 ;
                               owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                             ] ;
             rdfs:label "creep reference dataset"@en ;
             skos:definition "A creep reference dataset is a reference dataset that is composed of experimentally or computationally derived data about time-dependent deformation (creep) of materials under controlled conditions, and that serves as a trusted baseline for comparison, validation, or reuse." .


###  https://w3id.org/pmd/cto/CTO_0000010
:CTO_0000010 rdf:type owl:Class ;
             rdfs:subClassOf [ owl:intersectionOf ( <https://w3id.org/pmd/tto/TTO_0000034>
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:BFO_0000054 ;
                                                      owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:RO_0000052 ;
                                                      owl:someValuesFrom :CTO_0000008
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             rdfs:label "percentage creep extension"@en ;
             skos:definition "Extension at loading determined as difference between ep​ and ei​." .


###  https://w3id.org/pmd/cto/CTO_0000011
:CTO_0000011 rdf:type owl:Class ;
             rdfs:subClassOf <https://w3id.org/pmd/co/PMD_0000522> ;
             rdfs:label "loading process"@en ;
             skos:definition "A loading process is a mechanical process that applies forces or stresses to a material or specimen." .


###  https://w3id.org/pmd/cto/CTO_0000012
:CTO_0000012 rdf:type owl:Class ;
             rdfs:subClassOf <https://w3id.org/pmd/co/PMD_0000779> ;
             rdfs:label "solutionizing heat treatment process"@en ;
             skos:definition "A solutionizing process is a physical heat treatment process in which a material is heated to a specific elevated temperature and held there for a sufficient duration to completely dissolve secondary alloying phases or precipitates into the primary solid solution matrix, typically followed by rapid cooling (quenching) to trap those elements in a supersaturated state prior to aging." .


###  https://w3id.org/pmd/cto/CTO_0000013
:CTO_0000013 rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( obo:BFO_0000202
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty [ owl:inverseOf obo:BFO_0000199
                                                                         ] ;
                                                          owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf obo:BFO_0000202 ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty [ owl:inverseOf obo:BFO_0000199
                                              ] ;
                               owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                             ] ;
             rdfs:label "stress rupture time"@en ;
             skos:definition "A stress rupture time is a temporal interval that specifies the duration from the application of stress to the occurrence of rupture in a material." .


###  https://w3id.org/pmd/cto/CTO_0000014
:CTO_0000014 rdf:type owl:Class ;
             rdfs:subClassOf [ owl:intersectionOf ( <https://w3id.org/pmd/co/PMD_0000848>
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:BFO_0000054 ;
                                                      owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:RO_0000052 ;
                                                      owl:someValuesFrom :CTO_0000008
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             rdfs:label "stress exponent"@en ;
             skos:definition "A stress exponent is a mechanical property that characterizes the sensitivity of creep rate to applied stress, typically appearing as an exponent in creep rate equations." .


###  https://w3id.org/pmd/cto/CTO_0000015
:CTO_0000015 rdf:type owl:Class ;
             rdfs:subClassOf obo:BFO_0000030 ;
             rdfs:label "precipitate"@en ;
             skos:definition "A precipitate is an object that is a distinct solid phase formed within a material, typically by separation from a solution or matrix." .


###  https://w3id.org/pmd/cto/CTO_0000016
:CTO_0000016 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000015 ;
             rdfs:label "delta pricipitate"@en ;
             skos:definition "A delta precipitate is a precipitate that is a specific phase (typically δ-phase) formed within a material under particular thermodynamic and processing conditions." .


###  https://w3id.org/pmd/cto/CTO_0000017
:CTO_0000017 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000015 ;
             rdfs:label "gamma pricipitate"@en ;
             skos:definition "A gamma precipitate is a precipitate that is a γ-phase formed within a material, typically contributing to its mechanical properties." .


###  https://w3id.org/pmd/cto/CTO_0000018
:CTO_0000018 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000015 ;
             rdfs:label "gamma prime pricipitate"@en ;
             skos:definition "A gamma prime precipitate is a precipitate that is a γ′-phase formed within a material, typically strengthening it by hindering dislocation motion." .


###  https://w3id.org/pmd/cto/CTO_0000021
:CTO_0000021 rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( <http://purls.helmholtz-metadaten.de/mwo/MWO_0001099>
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty obo:IAO_0000219 ;
                                                          owl:someValuesFrom [ owl:intersectionOf ( :CTO_0000008
                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty obo:RO_0000056 ;
                                                                                                      owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                                                                                                    ]
                                                                                                  ) ;
                                                                               rdf:type owl:Class
                                                                             ]
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf <http://purls.helmholtz-metadaten.de/mwo/MWO_0001099> ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:IAO_0000219 ;
                               owl:someValuesFrom [ owl:intersectionOf ( :CTO_0000008
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty obo:RO_0000056 ;
                                                                           owl:someValuesFrom <https://w3id.org/pmd/co/PMD_0000589>
                                                                         ]
                                                                       ) ;
                                                    rdf:type owl:Class
                                                  ]
                             ] ;
             rdfs:label "creep material identifier"@en ;
             skos:definition "A creep material identifier is a material identifier that denotes a creep test piece which participates in a creep testing process. It uniquely identifies the material used in a creep experiment by specifying its string name, like \"Inconel 625\". typically found in the materials section, specimen description, or experimental setup of a scientific paper, and explicitly refers to the material of the target creep test piece" .


