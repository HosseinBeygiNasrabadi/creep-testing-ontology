                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf obo:OBI_0001931 ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty obo:OBI_0001927 ;
                               owl:someValuesFrom [ owl:intersectionOf ( :CTO_3000113
                                                                         [ rdf:type owl:Restriction ;
