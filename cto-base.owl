                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020104"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0025999"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/pmd/cto/CTO_0000018"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002350"/>
                                                <owl:someValuesFrom>
