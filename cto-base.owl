                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/cto/CTO_0000008"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep test piece identifier</rdfs:label>
        <skos:definition>A creep test piece identifier is an object identifier that denotes a creep test piece which participates in a creep testing process. It uniquely designates a specific specimen used in a creep experiment. It appears as an alphanumeric code, label, or sample name (e.g., &quot;HT1&quot;, &quot;SSM_100&quot;, &quot;CLH4663&quot;), typically found in the specimen description, experimental setup table, or results section of a scientific paper, and explicitly refers to the individual creep test piece under investigation.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_1000005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_1000005">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001018"/>
