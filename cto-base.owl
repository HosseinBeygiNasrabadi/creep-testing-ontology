                                                                <owl:someValuesFrom>
                                                                    <owl:Class>
                                                                        <owl:intersectionOf rdf:parseType="Collection">
                                                                            <rdf:Description rdf:about="https://w3id.org/pmd/cto/CTO_0000008"/>
                                                                            <owl:Restriction>
                                                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                                                                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                                                                            </owl:Restriction>
                                                                        </owl:intersectionOf>
                                                                    </owl:Class>
                                                                </owl:someValuesFrom>
                                                            </owl:Restriction>
                                                        </owl:intersectionOf>
                                                    </owl:Class>
                                                </owl:someValuesFrom>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep test piece grain size value</rdfs:label>
        <skos:definition>A creep test piece grain size value is a scalar value specification that specifies the value of the grain size of a crystallite which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the average or representative grain dimension of the material microstructure. It appears as a numeric value with a length unit (e.g., &quot;170 μm&quot;, &quot;80–190 μm&quot;), typically found in the microstructure characterization section, results table, or specimen description of a scientific paper, and explicitly refers to the grain size of the target creep test piece.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000024 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000024">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000206"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000058"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0000260"/>
                                    <owl:Restriction>
                                        <owl:onProperty>
                                            <rdf:Description>
                                                <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000081"/>
                                            </rdf:Description>
                                        </owl:onProperty>
                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                                    </owl:Restriction>
