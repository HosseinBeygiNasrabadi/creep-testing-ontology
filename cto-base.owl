                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep test piece aging description</rdfs:label>
        <skos:definition>A creep test piece aging description is a textual description that denotes an aging process which performed before creep testing process. It describes the precipitation hardening or aging heat treatment applied to the creep test piece prior to testing. It appears as a text string specifying temperature, duration, cooling rate, and number of steps (e.g., &quot;720°C, 8 h/FC 57 K/h to 620°C, 8 h/AC&quot;), typically found in the heat treatment or specimen preparation section of a scientific paper, and explicitly refers to the aging treatment applied to the target creep test piece.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_1000009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_1000009">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="en">data acquisition system</rdfs:label>
        <skos:definition>The central unit collecting signals from load cells, extensometers, and thermocouples.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_1000010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_1000010">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000975"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_0000008"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000975"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000081"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_0000008"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep test piece role</rdfs:label>
        <skos:definition>The realizable entity that the specimen plays during the experiment (i.e., being the object under stress).</skos:definition>
    </owl:Class>
    


