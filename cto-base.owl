                                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purls.helmholtz-metadaten.de/mwo/MWO_0001099"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/pmd/cto/CTO_0000008"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep material identifier</rdfs:label>
        <skos:definition>A creep material identifier is a material identifier that denotes a creep test piece which participates in a creep testing process. It uniquely identifies the material used in a creep experiment by specifying its string name, like &quot;Inconel 625&quot;. typically found in the materials section, specimen description, or experimental setup of a scientific paper, and explicitly refers to the material of the target creep test piece</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000022 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000022">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0025002"/>
                    <owl:Restriction>
                        <owl:onProperty>
