                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0020243"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000663"/>
