    <!-- https://w3id.org/pmd/cto/CTO_0000002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cto/CTO_0000006"/>
        <rdfs:label>single test piece machine</rdfs:label>
        <skos:definition>Testing machine that permits straining of a single test piece.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000005">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/tto/TTO_0000033"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_0000008"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/tto/TTO_0000033"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_0000008"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">percentage elongation after creep fracture</rdfs:label>
        <skos:definition>A percentage elongation after creep fracture is a mechanical property that quantifies the relative increase in length of a material after creep fracture, expressed as a percentage.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000006">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001023"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000588"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purls.helmholtz-metadaten.de/mwo/MWO_0001023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000588"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep test machine type</rdfs:label>
        <skos:definition>A creep test machine type is a device type specification that classifies a device according to the type of creep testing machine it is.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cto/CTO_0000006"/>
        <rdfs:label>multiple test piece machine</rdfs:label>
        <skos:definition>Testing machine that permits straining of more than one test piece simultaneously.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000008">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_1000010"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_1000010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep test piece</rdfs:label>
        <skos:definition>A creep test piece is an object that is a material specimen prepared for and subjected to a creep test.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000009">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep reference dataset</rdfs:label>
        <skos:definition>A creep reference dataset is a reference dataset that is composed of experimentally or computationally derived data about time-dependent deformation (creep) of materials under controlled conditions, and that serves as a trusted baseline for comparison, validation, or reuse.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000010">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/tto/TTO_0000034"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_0000008"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">percentage creep extension</rdfs:label>
        <skos:definition>Extension at loading determined as difference between ep​ and ei​.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000011">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000522"/>
        <rdfs:label xml:lang="en">loading process</rdfs:label>
        <skos:definition>A loading process is a mechanical process that applies forces or stresses to a material or specimen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000012">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000779"/>
        <rdfs:label xml:lang="en">solutionizing heat treatment process</rdfs:label>
        <skos:definition>A solutionizing process is a physical heat treatment process in which a material is heated to a specific elevated temperature and held there for a sufficient duration to completely dissolve secondary alloying phases or precipitates into the primary solid solution matrix, typically followed by rapid cooling (quenching) to trap those elements in a supersaturated state prior to aging.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000013">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000202"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000199"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000202"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000199"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">stress rupture time</rdfs:label>
        <skos:definition>A stress rupture time is a temporal interval that specifies the duration from the application of stress to the occurrence of rupture in a material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000014">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000848"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000589"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cto/CTO_0000008"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">stress exponent</rdfs:label>
        <skos:definition>A stress exponent is a mechanical property that characterizes the sensitivity of creep rate to applied stress, typically appearing as an exponent in creep rate equations.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">precipitate</rdfs:label>
        <skos:definition>A precipitate is an object that is a distinct solid phase formed within a material, typically by separation from a solution or matrix.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000016">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cto/CTO_0000015"/>
        <rdfs:label xml:lang="en">delta pricipitate</rdfs:label>
        <skos:definition>A delta precipitate is a precipitate that is a specific phase (typically δ-phase) formed within a material under particular thermodynamic and processing conditions.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000017 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000017">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cto/CTO_0000015"/>
        <rdfs:label xml:lang="en">gamma pricipitate</rdfs:label>
        <skos:definition>A gamma precipitate is a precipitate that is a γ-phase formed within a material, typically contributing to its mechanical properties.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000018 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000018">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cto/CTO_0000015"/>
        <rdfs:label xml:lang="en">gamma prime pricipitate</rdfs:label>
        <skos:definition>A gamma prime precipitate is a precipitate that is a γ′-phase formed within a material, typically strengthening it by hindering dislocation motion.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_0000021 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_0000021">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purls.helmholtz-metadaten.de/mwo/MWO_0001099"/>
