        <rdfs:label xml:lang="en">creep rupture stress</rdfs:label>
        <skos:definition>The stress capable of causing fracture at a specific time and temperature.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_1000042 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_1000042">
        <rdfs:subClassOf>
