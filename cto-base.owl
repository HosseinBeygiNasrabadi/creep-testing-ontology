        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">creep test piece gamma prime precipitate size value</rdfs:label>
        <skos:definition>A creep test piece gamma prime precipitate size value is a scalar value specification that specifies the value of the size of a gamma prime precipitate which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the average or representative dimension of gamma prime phase particles in the material. It appears as a numeric value with a length unit (e.g., &quot;100 nm&quot;, &quot;0.2 μm&quot;), typically found in the microstructure characterization or TEM analysis section of a scientific paper, and explicitly refers to the gamma prime precipitate size in the target creep test piece.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_1000025 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_1000025">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0001931"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0001927"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/pmd/cto/CTO_3000114"/>
                                    <owl:Restriction>
