                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:IAO_0000119>https://w3id.org/pmd/co/Stress</obo:IAO_0000119>
        <rdfs:label xml:lang="en">creep threshold stress</rdfs:label>
        <skos:definition>The theoretical lower limiting stress below which no measurable creep deformation occurs.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cto/CTO_1000040 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cto/CTO_1000040">
