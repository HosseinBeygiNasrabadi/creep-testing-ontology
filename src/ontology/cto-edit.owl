SubClassOf(<https://w3id.org/pmd/CTO_0000002> <http://purl.obolibrary.org/obo/OBI_0001931>)

# Class: <https://w3id.org/pmd/CTO_0000008> (dataset DOI)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000008> "dataset DOI"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_0000008> "A persistent, universally unique alphanumeric string assigned by a registration agency to ensure the dataset remains permanently findable, accessible, and citable on the web.")
EquivalentClasses(<https://w3id.org/pmd/CTO_0000008> ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001037> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000219> <https://w3id.org/pmd/CTO_0000009>)))
SubClassOf(<https://w3id.org/pmd/CTO_0000008> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001037>)

# Class: <https://w3id.org/pmd/CTO_0000009> (creep reference dataset)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000009> "creep reference dataset"@en)
EquivalentClasses(<https://w3id.org/pmd/CTO_0000009> ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000312> <https://w3id.org/pmd/co/PMD_0000589>)))
SubClassOf(<https://w3id.org/pmd/CTO_0000009> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204>)

# Class: <https://w3id.org/pmd/CTO_0000011> (Processing method description)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000011> "Processing method description"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_0000011> "A processing method description is an information content entity that details the comprehensive sequence of primary manufacturing, shaping, and thermo-mechanical treatments (e.g., casting, forging, rolling) used to produce the material in its specific tested state.")
EquivalentClasses(<https://w3id.org/pmd/CTO_0000011> ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001018> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000219> <https://w3id.org/pmd/co/PMD_0000833>)))
SubClassOf(<https://w3id.org/pmd/CTO_0000011> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001018>)

# Class: <https://w3id.org/pmd/CTO_0000012> (solutionizing process)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000012> "solutionizing process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_0000012> "A solutionizing process is a physical heat treatment process in which a material is heated to a specific elevated temperature and held there for a sufficient duration to completely dissolve secondary alloying phases or precipitates into the primary solid solution matrix, typically followed by rapid cooling (quenching) to trap those elements in a supersaturated state prior to aging.")
SubClassOf(<https://w3id.org/pmd/CTO_0000012> <https://w3id.org/pmd/co/PMD_0000779>)

# Class: <https://w3id.org/pmd/CTO_0000013> (solutionizing process description)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000013> "solutionizing process description"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_0000013> "A solutionizing process description is an information content entity that documents the specific time and temperature parameters of the solution heat treatment performed to fully dissolve secondary alloying phases into the primary solid solution matrix prior to quenching.")
EquivalentClasses(<https://w3id.org/pmd/CTO_0000013> ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001018> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000219> <https://w3id.org/pmd/CTO_0000012>)))
SubClassOf(<https://w3id.org/pmd/CTO_0000013> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001018>)

# Class: <https://w3id.org/pmd/CTO_0000014> (Aging process description)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000014> "Aging process description"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_0000014> "An aging process description is an information content entity that formally documents the specific parameters—such as target temperature, hold time, and cooling rate—of the precipitation hardening heat treatment applied to a material to increase its strength.")
EquivalentClasses(<https://w3id.org/pmd/CTO_0000014> ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001018> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000219> <https://w3id.org/pmd/co/PMD_0000513>)))
SubClassOf(<https://w3id.org/pmd/CTO_0000014> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001018>)

# Class: <https://w3id.org/pmd/CTO_0000015> (precipitate size)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000015> "precipitate size"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_0000015> "A precipitation size (more formally referred to in materials science as precipitate size) is a scalar value specification representing the quantitative measurement of the average physical dimensions—such as the diameter, length, or thickness—of the secondary phase particles that have formed within a material's primary matrix during the precipitation heat treatment process.")
SubClassOf(<https://w3id.org/pmd/CTO_0000015> <https://w3id.org/pmd/co/PMD_0020131>)

# Class: <https://w3id.org/pmd/CTO_1000000> (creep test standard)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000000> "creep test standard"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000000> "The specific normative reference (e.g., ISO 204) governing the uniaxial creep test procedure.")
EquivalentClasses(<https://w3id.org/pmd/CTO_1000000> ObjectIntersectionOf(<https://w3id.org/pmd/CTO_1000000> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000058> <http://purl.obolibrary.org/obo/OBI_0000260>)))
SubClassOf(<https://w3id.org/pmd/CTO_1000000> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000206>)

# Class: <https://w3id.org/pmd/CTO_1000001> (creep test machine heating system)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/CTO_1000001> "https://www.iso.org/standard/67737.html")
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000001> "creep test machine heating system"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000001> "The heating device provided for heating the test piece to the prescribed temperature (T).")
SubClassOf(<https://w3id.org/pmd/CTO_1000001> <https://w3id.org/pmd/co/PMD_0000655>)

# Class: <https://w3id.org/pmd/CTO_1000002> (creep test machine loading sensor)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/CTO_1000002> "https://www.iso.org/standard/41931.html")
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000002> "creep test machine loading sensor"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000002> "The force transducer used to measure the applied load, verified to ISO 7500-2, Class 1 or better.")
SubClassOf(<https://w3id.org/pmd/CTO_1000002> <https://w3id.org/pmd/co/PMD_0000820>)

# Class: <https://w3id.org/pmd/CTO_1000003> (device designation)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000003> "device designation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000003> "A device designation is an information entity that serves as a unique alphanumeric identifier, serial number, or specific technical classification assigned to a distinct piece of measuring or testing equipment.")
SubClassOf(<https://w3id.org/pmd/CTO_1000003> <http://purl.obolibrary.org/obo/IAO_0020000>)

# Class: <https://w3id.org/pmd/CTO_1000004> (creep test machine identifier)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000004> "creep test machine identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000004> "The unique serial number or asset tag assigned to the specific testing rig.")
SubClassOf(<https://w3id.org/pmd/CTO_1000004> <https://w3id.org/pmd/CTO_1000003>)

# Class: <https://w3id.org/pmd/CTO_1000005> (load cell id)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000005> "load cell id"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000005> "The unique serial number for the load cell sensor.")
SubClassOf(<https://w3id.org/pmd/CTO_1000005> <https://w3id.org/pmd/CTO_1000003>)

# Class: <https://w3id.org/pmd/CTO_1000006> (extensometer id)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000006> "extensometer id"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000006> "The unique serial number for the extensometer.")
SubClassOf(<https://w3id.org/pmd/CTO_1000006> <https://w3id.org/pmd/CTO_1000003>)

# Class: <https://w3id.org/pmd/CTO_1000007> (temperature sensor id)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000007> "temperature sensor id"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000007> "The unique identifier for the specific thermocouple used.")
SubClassOf(<https://w3id.org/pmd/CTO_1000007> <https://w3id.org/pmd/CTO_1000003>)

# Class: <https://w3id.org/pmd/CTO_1000008> (device type specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000008> "device type specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000008> "The technical classification of the furnace (e.g., \"3-Zone Resistance Furnace\").")
