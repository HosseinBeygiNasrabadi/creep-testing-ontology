# Class: <https://w3id.org/pmd/CTO_1000055> (Percentage total extension value specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000055> "Percentage total extension value specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000055> "A Percentage total extension value specification is a scalar value specification representing the overall, combined extension measured at any specific point in time during the test while the specimen is under load, expressed as a percentage of the reference gauge length.")
EquivalentClasses(<https://w3id.org/pmd/CTO_1000055> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0001931> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0001927> <https://w3id.org/pmd/CTO_3000011>)))
SubClassOf(<https://w3id.org/pmd/CTO_1000055> <https://w3id.org/pmd/CTO_0000000>)

# Class: <https://w3id.org/pmd/CTO_1000056> (percentage initial total extension value specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000056> "percentage initial total extension value specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000056> "A percentage initial total extension value specification is a scalar value specification representing the total extension recorded at the exact moment the full test force is initially applied (consisting of both the initial elastic and initial plastic extensions), expressed as a percentage of the reference gauge length.")
EquivalentClasses(<https://w3id.org/pmd/CTO_1000056> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0001931> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0001927> <https://w3id.org/pmd/co/PMD_00000116>)))
SubClassOf(<https://w3id.org/pmd/CTO_1000056> <https://w3id.org/pmd/CTO_0000000>)

# Class: <https://w3id.org/pmd/CTO_1000057> (percentage elastic extension value specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000057> "percentage elastic extension value specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000057> "A percentage elastic extension value specification is a scalar value specification representing the measured portion of the extension that is fully recoverable upon unloading, which is proportional to the applied initial stress, and expressed as a percentage of the reference gauge length.")
EquivalentClasses(<https://w3id.org/pmd/CTO_1000057> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0001931> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0001927> <https://w3id.org/pmd/CTO_3000013>)))
SubClassOf(<https://w3id.org/pmd/CTO_1000057> <https://w3id.org/pmd/CTO_0000000>)

# Class: <https://w3id.org/pmd/CTO_1000058> (percentage initial plastic extension value specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000058> "percentage initial plastic extension value specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000058> "A percentage initial plastic extension value specification is a scalar value specification representing the non-recoverable (plastic) portion of the extension recorded at the exact moment the full test load is initially applied, expressed as a percentage of the reference gauge length.")
EquivalentClasses(<https://w3id.org/pmd/CTO_1000058> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0001931> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0001927> <https://w3id.org/pmd/co/PMD_00000119>)))
SubClassOf(<https://w3id.org/pmd/CTO_1000058> <https://w3id.org/pmd/CTO_0000000>)

# Class: <https://w3id.org/pmd/CTO_1000059> (percentage plastic extension value specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000059> "percentage plastic extension value specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000059> "A percentage plastic extension value specification is a scalar value specification representing the unrecoverable, permanent portion of the extension at any given time, calculated as the total extension minus the elastic extension, and expressed as a percentage of the reference gauge length.")
EquivalentClasses(<https://w3id.org/pmd/CTO_1000059> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0001931> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0001927> <https://w3id.org/pmd/co/PMD_00000121>)))
SubClassOf(<https://w3id.org/pmd/CTO_1000059> <https://w3id.org/pmd/CTO_0000000>)

# Class: <https://w3id.org/pmd/CTO_1000060> (percentage creep extension value specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000060> "percentage creep extension value specification"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000060> "A percentage creep extension value specification is a scalar value specification representing the time-dependent portion of the extension that accumulates gradually during the creep test, calculated as the total extension minus the initial total extension, and expressed as a percentage of the reference gauge length.")
EquivalentClasses(<https://w3id.org/pmd/CTO_1000060> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0001931> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0001927> <https://w3id.org/pmd/CTO_3000010>)))
SubClassOf(<https://w3id.org/pmd/CTO_1000060> <https://w3id.org/pmd/CTO_0000000>)

