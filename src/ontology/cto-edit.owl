# Class: <https://w3id.org/pmd/cto/CTO_0000001> (object identifier)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000001> "object identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000001> "Object identifier is an identifier that uniquely designates a specific object.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000001> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/IAO_0020000> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000136> <http://purl.obolibrary.org/obo/BFO_0000030>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000001> <http://purl.obolibrary.org/obo/IAO_0020000>)

# Class: <https://w3id.org/pmd/cto/CTO_0000002> (single test piece machine)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000002> "single test piece machine")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000002> "Testing machine that permits straining of a single test piece.")
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000002> <https://w3id.org/pmd/cto/CTO_0000006>)

# Class: <https://w3id.org/pmd/cto/CTO_0000003> (equation textual entity)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000003> "equation textual entity"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000003> "An equation textual entity is a textual entity that expresses a mathematical equation specifying relationships between quantities or variables.")
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000003> <http://purl.obolibrary.org/obo/IAO_0000300>)

# Class: <https://w3id.org/pmd/cto/CTO_0000004> (farcture mechanism)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000004> "farcture mechanism"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000004> "A fracture mechanism is a categorical value specification that classifies the mode by which a material fails under stress.")
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000004> <http://purl.obolibrary.org/obo/OBI_0001930>)

# Class: <https://w3id.org/pmd/cto/CTO_0000005> (percentage elongation after creep fracture)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000005> "percentage elongation after creep fracture"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000005> "A percentage elongation after creep fracture is a mechanical property that quantifies the relative increase in length of a material after creep fracture, expressed as a percentage.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000005> ObjectIntersectionOf(<https://w3id.org/pmd/tto/TTO_0000033> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000052> <https://w3id.org/pmd/cto/CTO_0000008>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000005> <https://w3id.org/pmd/tto/TTO_0000033>)

# Class: <https://w3id.org/pmd/cto/CTO_0000006> (creep test machine type)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000006> "creep test machine type"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000006> "A creep test machine type is a device type specification that classifies a device according to the type of creep testing machine it is.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000006> ObjectIntersectionOf(<https://w3id.org/pmd/cto/CTO_1000008> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000136> <https://w3id.org/pmd/co/PMD_0000588>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000006> <https://w3id.org/pmd/cto/CTO_1000008>)

# Class: <https://w3id.org/pmd/cto/CTO_0000007> (multiple test piece machine)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000007> "multiple test piece machine")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000007> "Testing machine that permits straining of more than one test piece simultaneously.")
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000007> <https://w3id.org/pmd/cto/CTO_0000006>)

# Class: <https://w3id.org/pmd/cto/CTO_0000008> (creep test piece)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000008> "creep test piece"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000008> "A creep test piece is an object that is a material specimen prepared for and subjected to a creep test.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000008> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000030> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000056> <https://w3id.org/pmd/co/PMD_0000589>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000087> <https://w3id.org/pmd/cto/CTO_1000010>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000008> <http://purl.obolibrary.org/obo/BFO_0000030>)

# Class: <https://w3id.org/pmd/cto/CTO_0000009> (creep reference dataset)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000009> "creep reference dataset"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000009> "A creep reference dataset is a reference dataset that is composed of experimentally or computationally derived data about time-dependent deformation (creep) of materials under controlled conditions, and that serves as a trusted baseline for comparison, validation, or reuse.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000009> ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000312> <https://w3id.org/pmd/co/PMD_0000589>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000009> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204>)

# Class: <https://w3id.org/pmd/cto/CTO_0000010> (percentage creep extension)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000010> "percentage creep extension"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000010> "Extension at loading determined as difference between ep​ and ei​.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000010> ObjectIntersectionOf(<https://w3id.org/pmd/tto/TTO_0000034> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> <https://w3id.org/pmd/co/PMD_0000589>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000052> <https://w3id.org/pmd/cto/CTO_0000008>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000010> <https://w3id.org/pmd/tto/TTO_0000034>)

# Class: <https://w3id.org/pmd/cto/CTO_0000011> (loading process)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000011> "loading process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000011> "A loading process is a mechanical process that applies forces or stresses to a material or specimen.")
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000011> <https://w3id.org/pmd/co/PMD_0000522>)

# Class: <https://w3id.org/pmd/cto/CTO_0000012> (solutionizing heat treatment process)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000012> "solutionizing heat treatment process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000012> "A solutionizing process is a physical heat treatment process in which a material is heated to a specific elevated temperature and held there for a sufficient duration to completely dissolve secondary alloying phases or precipitates into the primary solid solution matrix, typically followed by rapid cooling (quenching) to trap those elements in a supersaturated state prior to aging.")
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000012> <https://w3id.org/pmd/co/PMD_0000779>)

# Class: <https://w3id.org/pmd/cto/CTO_0000013> (stress rupture time)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000013> "stress rupture time"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000013> "A stress rupture time is a temporal interval that specifies the duration from the application of stress to the occurrence of rupture in a material.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000013> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000202> ObjectSomeValuesFrom(ObjectInverseOf(<http://purl.obolibrary.org/obo/BFO_0000199>) <https://w3id.org/pmd/co/PMD_0000589>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000013> <http://purl.obolibrary.org/obo/BFO_0000202>)

# Class: <https://w3id.org/pmd/cto/CTO_0000014> (stress exponent)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000014> "stress exponent"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000014> "A stress exponent is a mechanical property that characterizes the sensitivity of creep rate to applied stress, typically appearing as an exponent in creep rate equations.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000014> ObjectIntersectionOf(<https://w3id.org/pmd/co/PMD_0000848> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> <https://w3id.org/pmd/co/PMD_0000589>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000052> <https://w3id.org/pmd/cto/CTO_0000008>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000014> <https://w3id.org/pmd/co/PMD_0000848>)

# Class: <https://w3id.org/pmd/cto/CTO_0000015> (precipitate)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000015> "precipitate"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000015> "A precipitate is an object that is a distinct solid phase formed within a material, typically by separation from a solution or matrix.")
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000015> <http://purl.obolibrary.org/obo/BFO_0000030>)

# Class: <https://w3id.org/pmd/cto/CTO_0000016> (delta pricipitate)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000016> "delta pricipitate"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000016> "A delta precipitate is a precipitate that is a specific phase (typically δ-phase) formed within a material under particular thermodynamic and processing conditions.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000016> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000040> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002350> <https://w3id.org/pmd/co/PMD_0000857>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000016> <https://w3id.org/pmd/cto/CTO_0000015>)

# Class: <https://w3id.org/pmd/cto/CTO_0000017> (gamma pricipitate)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000017> "gamma pricipitate"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000017> "A gamma precipitate is a precipitate that is a γ-phase formed within a material, typically contributing to its mechanical properties.")
EquivalentClasses(<https://w3id.org/pmd/cto/CTO_0000017> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000040> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002350> <https://w3id.org/pmd/co/PMD_0000857>)))
SubClassOf(<https://w3id.org/pmd/cto/CTO_0000017> <https://w3id.org/pmd/cto/CTO_0000015>)

# Class: <https://w3id.org/pmd/cto/CTO_0000018> (gamma prime pricipitate)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cto/CTO_0000018> "gamma prime pricipitate"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cto/CTO_0000018> "A gamma prime precipitate is a precipitate that is a γ′-phase formed within a material, typically strengthening it by hindering dislocation motion.")
