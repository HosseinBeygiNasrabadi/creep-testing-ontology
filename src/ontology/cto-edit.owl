SubClassOf(<https://w3id.org/pmd/CTO_0000004> <http://purl.obolibrary.org/obo/OBI_0001930>)

# Class: <https://w3id.org/pmd/CTO_0000005> (percentage elongation after creep fracture)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000005> "percentage elongation after creep fracture"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000005> <https://w3id.org/pmd/tto/TTO_0000033>)

# Class: <https://w3id.org/pmd/CTO_0000006> (creep test machine type)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000006> "creep test machine type"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000006> <https://w3id.org/pmd/CTO_1000008>)

# Class: <https://w3id.org/pmd/CTO_0000007> (delta precipitate role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000007> "delta precipitate role"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000007> <https://w3id.org/pmd/co/PMD_0020002>)

# Class: <https://w3id.org/pmd/CTO_0000008> (gamma precipitate role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000008> "gamma precipitate role"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000008> <https://w3id.org/pmd/co/PMD_0020002>)

# Class: <https://w3id.org/pmd/CTO_0000009> (creep reference dataset)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000009> "creep reference dataset"@en)
EquivalentClasses(<https://w3id.org/pmd/CTO_0000009> ObjectIntersectionOf(<https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000312> <https://w3id.org/pmd/co/PMD_0000589>)))
SubClassOf(<https://w3id.org/pmd/CTO_0000009> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0001204>)

# Class: <https://w3id.org/pmd/CTO_0000010> (gamma prime precipitate role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000010> "gamma prime precipitate role"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000010> <https://w3id.org/pmd/co/PMD_0020002>)

# Class: <https://w3id.org/pmd/CTO_0000011> (loading process)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000011> "loading process"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000011> <https://w3id.org/pmd/co/PMD_0000522>)

# Class: <https://w3id.org/pmd/CTO_0000012> (solutionizing heat treatment process)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000012> "solutionizing heat treatment process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_0000012> "A solutionizing process is a physical heat treatment process in which a material is heated to a specific elevated temperature and held there for a sufficient duration to completely dissolve secondary alloying phases or precipitates into the primary solid solution matrix, typically followed by rapid cooling (quenching) to trap those elements in a supersaturated state prior to aging.")
SubClassOf(<https://w3id.org/pmd/CTO_0000012> <https://w3id.org/pmd/co/PMD_0000779>)

# Class: <https://w3id.org/pmd/CTO_0000013> (stress rupture time)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000013> "stress rupture time"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000013> <http://purl.obolibrary.org/obo/BFO_0000202>)

# Class: <https://w3id.org/pmd/CTO_0000014> (stress exponent)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_0000014> "stress exponent"@en)
SubClassOf(<https://w3id.org/pmd/CTO_0000014> <https://w3id.org/pmd/co/PMD_0000848>)

# Class: <https://w3id.org/pmd/CTO_1000000> (creep test standard)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000000> "creep test standard"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000000> "The specific normative reference (e.g., ISO 204) governing the uniaxial creep test procedure.")
SubClassOf(<https://w3id.org/pmd/CTO_1000000> <https://nfdi.fiz-karlsruhe.de/ontology/NFDI_0000206>)

# Class: <https://w3id.org/pmd/CTO_1000001> (creep test machine heating system)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/CTO_1000001> "https://www.iso.org/standard/67737.html")
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000001> "creep test machine heating system"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000001> "The heating device provided for heating the test piece to the prescribed temperature (T).")
SubClassOf(<https://w3id.org/pmd/CTO_1000001> <https://w3id.org/pmd/co/PMD_0000655>)

# Class: <https://w3id.org/pmd/CTO_1000002> (creep test machine loading sensor)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/CTO_1000002> "https://www.iso.org/standard/41931.html")
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000002> "creep test machine loading sensor"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000002> "The force transducer used to measure the applied load, verified to ISO 7500-2, Class 1 or better.")
SubClassOf(<https://w3id.org/pmd/CTO_1000002> <https://w3id.org/pmd/co/PMD_0000820>)

# Class: <https://w3id.org/pmd/CTO_1000003> (device identifier)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000003> "device identifier"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000003> "A device designation is an information entity that serves as a unique alphanumeric identifier, serial number, or specific technical classification assigned to a distinct piece of measuring or testing equipment.")
SubClassOf(<https://w3id.org/pmd/CTO_1000003> <https://w3id.org/pmd/CTO_0000001>)

# Class: <https://w3id.org/pmd/CTO_1000008> (device type specification)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000008> "device type specification"@en)
SubClassOf(<https://w3id.org/pmd/CTO_1000008> <http://purl.obolibrary.org/obo/OBI_0001930>)

# Class: <https://w3id.org/pmd/CTO_1000009> (data acquisition system)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000009> "data acquisition system"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000009> "The central unit collecting signals from load cells, extensometers, and thermocouples.")
SubClassOf(<https://w3id.org/pmd/CTO_1000009> <https://w3id.org/pmd/co/PMD_0000602>)

# Class: <https://w3id.org/pmd/CTO_1000010> (creep test piece role)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000010> "creep test piece role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000010> "The realizable entity that the specimen plays during the experiment (i.e., being the object under stress).")
SubClassOf(<https://w3id.org/pmd/CTO_1000010> <https://w3id.org/pmd/co/PMD_0000975>)

# Class: <https://w3id.org/pmd/CTO_1000013> (material state)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000013> "material state"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000013> "A descriptor defining the processing history or physical condition of the material before or after testing.")
SubClassOf(<https://w3id.org/pmd/CTO_1000013> <http://purl.obolibrary.org/obo/OBI_0001930>)

# Class: <https://w3id.org/pmd/CTO_1000014> (as manufactured)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000014> "as manufactured"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000014> "The condition of the material immediately after the primary manufacturing process (casting/forging) without further treatment.")
SubClassOf(<https://w3id.org/pmd/CTO_1000014> <https://w3id.org/pmd/CTO_1000013>)

# Class: <https://w3id.org/pmd/CTO_1000015> (heat treated)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000015> "heat treated"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000015> "The condition of the material resulting from a controlled heating and cooling process to alters its physical properties.")
SubClassOf(<https://w3id.org/pmd/CTO_1000015> <https://w3id.org/pmd/CTO_1000013>)

# Class: <https://w3id.org/pmd/CTO_1000016> (as tested)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000016> "as tested"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000016> "The specific state of the material at the exact moment the test begins (including all pre-test preparations).")
SubClassOf(<https://w3id.org/pmd/CTO_1000016> <https://w3id.org/pmd/CTO_1000013>)

# Class: <https://w3id.org/pmd/CTO_1000017> (fractured)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000017> "fractured"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000017> "The condition of the test piece after the creep rupture limit has been reached and the material has separated.")
SubClassOf(<https://w3id.org/pmd/CTO_1000017> <https://w3id.org/pmd/CTO_1000013>)

# Class: <https://w3id.org/pmd/CTO_1000018> (normalized)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000018> "normalized"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000018> "State resulting from heating to an austenitizing temperature and cooling in air to refine the grain structure.")
SubClassOf(<https://w3id.org/pmd/CTO_1000018> <https://w3id.org/pmd/CTO_1000015>)

# Class: <https://w3id.org/pmd/CTO_1000019> (annealed)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000019> "annealed")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000019> "State resulting from heating to a specific temperature and cooling at a controlled rate to remove internal stresses.")
SubClassOf(<https://w3id.org/pmd/CTO_1000019> <https://w3id.org/pmd/CTO_1000015>)

# Class: <https://w3id.org/pmd/CTO_1000020> (aged)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000020> "aged"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000020> "State resulting from precipitation hardening (holding at an intermediate temperature) to increase strength.")
SubClassOf(<https://w3id.org/pmd/CTO_1000020> <https://w3id.org/pmd/CTO_1000015>)

# Class: <https://w3id.org/pmd/CTO_1000027> (reference length to calculate percentage elongation)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000027> "reference length to calculate percentage elongation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000027> "The standard length used for the calculation of ductility (elongation) at the end of the test, often defined by standards relative to the diameter (e.g., $5d$).")
SubClassOf(<https://w3id.org/pmd/CTO_1000027> <https://w3id.org/pmd/co/PMD_0040001>)

# Class: <https://w3id.org/pmd/CTO_1000028> (reference length to calculate percentage extension)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/CTO_1000028> "reference length to calculate percentage extension"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/CTO_1000028> "The length used to calculate non-proportional extension, often distinct from elongation in specific creep contexts involving plastic deformation.")
SubClassOf(<https://w3id.org/pmd/CTO_1000028> <https://w3id.org/pmd/co/PMD_0040001>)

# Class: <https://w3id.org/pmd/CTO_1000030> (assay identifier)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <https://w3id.org/pmd/CTO_1000030> "https://w3id.org/nfdi4ing/metadata/identifier")
