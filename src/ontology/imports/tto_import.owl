############################
#   Annotation Properties
############################

# Annotation Property: rdfs:label (label)

AnnotationAssertion(rdfs:label rdfs:label "label")
AnnotationAssertion(rdfs:label rdfs:label "label"@en)



############################
#   Classes
############################

# Class: <https://w3id.org/pmd/co/PMD_0000848> (mechanical property)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0000848> "mechanical property"@en)

# Class: <https://w3id.org/pmd/co/PMD_0040001> (length)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0040001> "length"@en)

# Class: <https://w3id.org/pmd/tto/TTO_0000004> (elongation)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/tto/TTO_0000004> "Verlängerung"@de)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/tto/TTO_0000004> "elongation"@en)
SubClassOf(<https://w3id.org/pmd/tto/TTO_0000004> <https://w3id.org/pmd/co/PMD_0000848>)

# Class: <https://w3id.org/pmd/tto/TTO_0000005> (extension)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/tto/TTO_0000005> "Verlängerung (der Extensometer-Messlänge)"@de)
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/tto/TTO_0000005> "extension"@en)
SubClassOf(<https://w3id.org/pmd/tto/TTO_0000005> <https://w3id.org/pmd/co/PMD_0000848>)

# Class: <https://w3id.org/pmd/tto/TTO_0000017> (extensometer gauge length)

