#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000050
obo:BFO_0000050 rdf:type owl:ObjectProperty ,
                         owl:TransitiveProperty ;
                obo:IAO_0000112 "my brain is part of my body (continuant parthood, two material entities)"@en ,
                                "my stomach cavity is part of my stomach (continuant parthood, immaterial entity is part of material entity)"@en ,
                                "this day is part of this year (occurrent parthood)"@en ;
                obo:IAO_0000115 "a core relation that holds between a part and its whole"@en ;
                obo:IAO_0000116 "Everything is part of itself. Any part of any part of a thing is itself part of that thing. Two distinct things cannot be part of each other."@en ,
                                "Occurrents are not subject to change and so parthood between occurrents holds for all the times that the part exists. Many continuants are subject to change, so parthood between continuants will only hold at certain times, but this is difficult to specify in OWL. See http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/"@en ,
                                """Parthood requires the part and the whole to have compatible classes: only an occurrent can be part of an occurrent; only a process can be part of a process; only a continuant can be part of a continuant; only an independent continuant can be part of an independent continuant; only an immaterial entity can be part of an immaterial entity; only a specifically dependent continuant can be part of a specifically dependent continuant; only a generically dependent continuant can be part of a generically dependent continuant. (This list is not exhaustive.)

A continuant cannot be part of an occurrent: use 'participates in'. An occurrent cannot be part of a continuant: use 'has participant'. A material entity cannot be part of an immaterial entity: use 'has location'. A specifically dependent continuant cannot be part of an independent continuant: use 'inheres in'. An independent continuant cannot be part of a specifically dependent continuant: use 'bearer of'."""@en ;
                rdfs:label "part of"@en .


###  http://purl.obolibrary.org/obo/BFO_0000054
obo:BFO_0000054 rdf:type owl:ObjectProperty ;
                rdfs:label "has realization"@en ,
                           "realized in"@en ;
                skos:definition "b has realization c =Def c realizes b"@en ;
                skos:example "As for realizes"@en .


###  http://purl.obolibrary.org/obo/BFO_0000062
obo:BFO_0000062 rdf:type owl:ObjectProperty ,
                         owl:TransitiveProperty ;
                obo:IAO_0000115 "x is preceded by y if and only if the time point at which y ends is before or equivalent to the time point at which x starts. Formally: x preceded by y iff ω(y) <= α(x), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point."@en ;
                rdfs:label "preceded by"@en ;
                skos:definition "b preceded by c =Def b precedes c"@en ;
                skos:example "The temporal region occupied by the second half of the match is preceded by the temporal region occupied by the first half of the match"@en .


###  http://purl.obolibrary.org/obo/BFO_0000199
obo:BFO_0000199 rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:label "occupies temporal region"@en ;
                skos:definition "p occupies temporal region t =Def p is a process or process boundary & the spatiotemporal region occupied by p temporally projects onto t"@en ;
                skos:example "The Second World War occupies the temporal region September 1, 1939 - September 2, 1945"@en .


###  http://purl.obolibrary.org/obo/COB_0000081
obo:COB_0000081 rdf:type owl:ObjectProperty ;
                rdfs:label "intended to realize"@en .


###  http://purl.obolibrary.org/obo/IAO_0000136
obo:IAO_0000136 rdf:type owl:ObjectProperty ;
                owl:inverseOf <https://w3id.org/pmd/co/PMD_0000004> ;
                obo:IAO_0000112 "This document is about information artifacts and their representations"@en ;
                obo:IAO_0000115 "A (currently) primitive relation that relates an information artifact to an entity."@en ;
                obo:IAO_0000116 """7/6/2009 Alan Ruttenberg. Following discussion with Jonathan Rees, and introduction of \"mentions\" relation. Weaken the is_about relationship to be primitive. 

We will try to build it back up by elaborating the various subproperties that are more precisely defined.

Some currently missing phenomena that should be considered \"about\" are predications - \"The only person who knows the answer is sitting beside me\" , Allegory, Satire, and other literary forms that can be topical without explicitly mentioning the topic."""@en ;
                obo:IAO_0000119 "Smith, Ceusters, Ruttenberg, 2000 years of philosophy"@en ;
                rdfs:label "is about"@en .


###  http://purl.obolibrary.org/obo/IAO_0000219
obo:IAO_0000219 rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf obo:IAO_0000136 ;
                obo:IAO_0000112 "A person's name denotes the person. A variable name in a computer program denotes some piece of memory. Lexically equivalent strings can denote different things, for instance \"Alan\" can denote different people. In each case of use, there is a case of the denotation relation obtaining, between \"Alan\" and the person that is being named."@en ;
                obo:IAO_0000115 "A primitive, instance-level, relation obtaining between an information content entity and some portion of reality. Denotation is what happens when someone creates an information content entity E in order to specifically refer to something. The only relation between E and the thing is that E can be used to 'pick out' the thing. This relation connects those two together. Freedictionary.com sense 3: To signify directly; refer to specifically"@en ;
                obo:IAO_0000116 """2009-11-10 Alan Ruttenberg. Old definition said the following to emphasize the generic nature of this relation. We no longer have 'specifically denotes', which would have been primitive, so make this relation primitive.
g denotes r =def 
r is a portion of reality
there is some c that is a concretization of g 
every c that is a concretization of g specifically denotes r"""@en ;
                obo:IAO_0000119 "Conversations with Barry Smith, Werner Ceusters, Bjoern Peters, Michel Dumontier, Melanie Courtot, James Malone, Bill Hogan"@en ;
                rdfs:comment ""@en ;
                rdfs:label "denotes"@en .


###  http://purl.obolibrary.org/obo/IAO_0000419
obo:IAO_0000419 rdf:type owl:ObjectProperty ;
                obo:IAO_0000115 "inverse of the relation of is quality specification of"@en ;
                obo:IAO_0000116 "2009/10/19 Alan Ruttenberg. Named 'junk' relation useful in restrictions, but not a real instance relationship"@en ;
                rdfs:label "quality is specified as"@en .


###  http://purl.obolibrary.org/obo/OBI_0000312
obo:OBI_0000312 rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf obo:RO_0000056 ;
                obo:IAO_0000115 "A relation between a completely executed planned process and a continuant participating in that process. The presence of the continuant at the end of the process is explicitly specified in the objective specification which the process realizes the concretization of."@en ;
                rdfs:label "is specified output of"@en .


###  http://purl.obolibrary.org/obo/OBI_0001927
obo:OBI_0001927 rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf obo:IAO_0000136 ;
                obo:IAO_0000115 "A relation between a value specification and an entity which the specification is about."@en ;
                rdfs:label "specifies value of" .


###  http://purl.obolibrary.org/obo/RO_0000052
obo:RO_0000052 rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               obo:IAO_0000112 "this fragility is a characteristic of this vase"@en ,
                               "this red color is a characteristic of this apple"@en ;
               obo:IAO_0000115 "a relation between a specifically dependent continuant (the characteristic) and any other entity (the bearer), in which the characteristic depends on the bearer for its existence."@en ;
               rdfs:comment "Note that this relation was previously called \"inheres in\", but was changed to be called \"characteristic of\" because BFO2 uses \"inheres in\" in a more restricted fashion. This relation differs from BFO2:inheres_in in two respects: (1) it does not impose a range constraint, and thus it allows qualities of processes, as well as of information entities, whereas BFO2 restricts inheres_in to only apply to independent continuants (2) it is declared functional, i.e. something can only be a characteristic of one thing." ;
               rdfs:label "characteristic of"@en .


###  http://purl.obolibrary.org/obo/RO_0000056
obo:RO_0000056 rdf:type owl:ObjectProperty ;
               obo:IAO_0000112 "this blood clot participates in this blood coagulation"@en ,
                               "this input material (or this output material) participates in this process"@en ,
                               "this investigator participates in this investigation"@en ;
               obo:IAO_0000115 "a relation between a continuant and a process, in which the continuant is somehow involved in the process"@en ;
               rdfs:label "participates in"@en .


###  http://purl.obolibrary.org/obo/RO_0000058
obo:RO_0000058 rdf:type owl:ObjectProperty ;
               obo:IAO_0000112 "A journal article is an information artifact that inheres in some number of printed journals. For each copy of the printed journal there is some quality that carries the journal article, such as a pattern of ink. The journal article (a generically dependent continuant) is concretized as the quality (a specifically dependent continuant), and both depend on that copy of the printed journal (an independent continuant)."@en ,
                               "An investigator reads a protocol and forms a plan to carry out an assay. The plan is a realizable entity (a specifically dependent continuant) that concretizes the protocol (a generically dependent continuant), and both depend on the investigator (an independent continuant). The plan is then realized by the assay (a process)."@en ;
               obo:IAO_0000115 "A relationship between a generically dependent continuant and a specifically dependent continuant or process, in which the generically dependent continuant depends on some independent continuant or process in virtue of the fact that the specifically dependent continuant or process also depends on that same independent continuant. A generically dependent continuant may be concretized as multiple specifically dependent continuants or processes."@en ,
                               "A relationship between a generically dependent continuant and a specifically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant also depends on that same independent continuant. A generically dependent continuant may be concretized as multiple specifically dependent continuants."@en ;
               rdfs:label "is concretized as"@en .


###  http://purl.obolibrary.org/obo/RO_0000080
obo:RO_0000080 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:RO_0000052 ;
               obo:IAO_0000112 "this red color is a quality of this apple"@en ;
               obo:IAO_0000115 "a relation between a quality and an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence"@en ;
               obo:IAO_0000116 "A quality inheres in its bearer at all times for which the quality exists."@en ;
               rdfs:comment "This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020." ;
               rdfs:label "quality of"@en .


###  http://purl.obolibrary.org/obo/RO_0000081
obo:RO_0000081 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:RO_0000052 ;
               owl:inverseOf obo:RO_0000087 ;
               obo:IAO_0000112 "this investigator role is a role of this person"@en ;
               obo:IAO_0000115 "a relation between a role and an independent continuant (the bearer), in which the role specifically depends on the bearer for its existence"@en ;
               obo:IAO_0000116 "A role inheres in its bearer at all times for which the role exists, however the role need not be realized at all the times that the role exists."@en ;
               rdfs:comment "This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020." ;
               rdfs:label "role of"@en .


###  http://purl.obolibrary.org/obo/RO_0000087
obo:RO_0000087 rdf:type owl:ObjectProperty ;
               obo:IAO_0000112 "this person has role this investigator role (more colloquially: this person has this role of investigator)"@en ;
               obo:IAO_0000115 "a relation between an independent continuant (the bearer) and a role, in which the role specifically depends on the bearer for its existence"@en ;
               obo:IAO_0000116 "A bearer can have many roles, and its roles can exist for different periods of time, but none of its roles can exist when the bearer does not exist. A role need not be realized at all the times that the role exists."@en ;
               rdfs:label "has role"@en .


###  http://purl.obolibrary.org/obo/RO_0002350
obo:RO_0002350 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:BFO_0000050 ;
               obo:IAO_0000112 "An organism that is a member of a population of organisms" ;
               obo:IAO_0000115 "is member of is a mereological relation between a item and a collection." ;
               obo:IAO_0000119 "SIO" ;
               rdfs:label "member of"@en .


###  http://purl.obolibrary.org/obo/RO_0002353
obo:RO_0002353 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:RO_0000056 ;
               obo:IAO_0000115 "inverse of has output" ;
               rdfs:label "output of"@en .


###  https://w3id.org/pmd/co/PMD_0000004
<https://w3id.org/pmd/co/PMD_0000004> rdf:type owl:ObjectProperty ;
                                      rdfs:label "is subject of"@en ;
                                      skos:definition "Inverse of 'is about'."@en .


###  https://w3id.org/pmd/co/PMD_0020127
<https://w3id.org/pmd/co/PMD_0020127> rdf:type owl:ObjectProperty ;
                                      rdfs:comment """Despite has characteristic from RO does not have any domain constraints, it is still not possible to directly connect an instance of a process with an instance of a SDC. 

First, SDC is dependent on a IC. As RO does not have \"bearer of\" object property, the \"has characteristic\" implies that the domain should be an IC. 

Second, characteristic of is a functional property. Thus, two triples SDC_1 characteristc of IC_1 and SDC_2  characteristc of Process_1 (where IC_1 participates in Process_1), cannot exist simultaneously. 
An example of such case can be \"Temperature of during the annealing process was 1000°C\". Temperature is an SDC of some participant of the annealing, however it is not clear whether it is an SDC of an oven or of a sample in the oven. If we assert triple Annealing--> has characteristic --> Temperature 1000°C, then the correct triple connecting temperature SDC with either oven or specimen cannot exist."""@en ;
                                      rdfs:label "refers to"@en ;
                                      skos:definition "a relation between a process attribute and an SDC of some participant in a process"@en ;
                                      skos:example "a relation to between a process attribute an a SDC of some participant in a process."@en .


###  https://w3id.org/pmd/co/PMD_0025006
<https://w3id.org/pmd/co/PMD_0025006> rdf:type owl:ObjectProperty ;
                                      rdfs:label "process attribute of"@en ;
                                      skos:definition "A relation between a process attribute and a process, which \"bears\" the attribute."@en ;
                                      skos:example "Tensile rate is a process attribute of tensile test"@en .


###  https://w3id.org/pmd/co/PMD_0025013
<https://w3id.org/pmd/co/PMD_0025013> rdf:type owl:ObjectProperty ;
                                      rdfs:label "changes quality"@en ;
                                      skos:definition "indicates that a process changes a quality"@en .


###  https://w3id.org/pmd/co/PMD_0025999
<https://w3id.org/pmd/co/PMD_0025999> rdf:type owl:ObjectProperty ;
                                      owl:propertyChainAxiom ( <https://w3id.org/pmd/co/PMD_0025999>
                                                               obo:BFO_0000050
                                                             ) ;
                                      obo:IAO_0000116 """The 'relational quality of' is more strict that 'quality of' from RO, since domain is 'relational quality'. The motivtion to introduce an object property for relational qualities is the following:
RO's 'quality of' is functional i.e., a->b, a->c => b=c. The functionality is relevant for most of the SDC -> IC triples, expect for relational qualities, which per definiton can be simultaneously inherited in >=2 ICs. Thus,  'relational quality of'  has the same intention to connect SDC to IC, however, without cardinality constraints."""@en ;
                                      rdfs:label "relational quality of"@en ;
                                      skos:definition "a relation between a relational quality and an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence"@en ;
                                      skos:example "mass proportion m is relational qualitiy of material, and the same mass proportion m is relational qualitiy of portion of iron"@en .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/pmd/cto/CTO_0000002
:CTO_0000002 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000006 ;
             rdfs:label "single test piece machine" ;
             skos:definition "Testing machine that permits straining of a single test piece." .


###  https://w3id.org/pmd/cto/CTO_0000005
:CTO_0000005 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000052 ;
                               owl:someValuesFrom :CTO_0000008
                             ] ;
             rdfs:label "percentage elongation after creep fracture"@en ;
             skos:definition "A percentage elongation after creep fracture is a mechanical property that quantifies the relative increase in length of a material after creep fracture, expressed as a percentage." .


###  https://w3id.org/pmd/cto/CTO_0000006
:CTO_0000006 rdf:type owl:Class ;
             rdfs:label "creep test machine type"@en ;
             skos:definition "A creep test machine type is a device type specification that classifies a device according to the type of creep testing machine it is." .


###  https://w3id.org/pmd/cto/CTO_0000007
:CTO_0000007 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000006 ;
             rdfs:label "multiple test piece machine" ;
             skos:definition "Testing machine that permits straining of more than one test piece simultaneously." .


###  https://w3id.org/pmd/cto/CTO_0000008
:CTO_0000008 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000087 ;
                               owl:someValuesFrom :CTO_1000010
                             ] ;
             rdfs:label "creep test piece"@en ;
             skos:definition "A creep test piece is an object that is a material specimen prepared for and subjected to a creep test." .


###  https://w3id.org/pmd/cto/CTO_0000009
:CTO_0000009 rdf:type owl:Class ;
             rdfs:label "creep reference dataset"@en ;
             skos:definition "A creep reference dataset is a reference dataset that is composed of experimentally or computationally derived data about time-dependent deformation (creep) of materials under controlled conditions, and that serves as a trusted baseline for comparison, validation, or reuse." .


###  https://w3id.org/pmd/cto/CTO_0000010
:CTO_0000010 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000052 ;
                               owl:someValuesFrom :CTO_0000008
                             ] ;
             rdfs:label "percentage creep extension"@en ;
             skos:definition "Extension at loading determined as difference between ep​ and ei​." .


###  https://w3id.org/pmd/cto/CTO_0000011
:CTO_0000011 rdf:type owl:Class ;
             rdfs:label "loading process"@en ;
             skos:definition "A loading process is a mechanical process that applies forces or stresses to a material or specimen." .


###  https://w3id.org/pmd/cto/CTO_0000012
:CTO_0000012 rdf:type owl:Class ;
             rdfs:label "solutionizing heat treatment process"@en ;
             skos:definition "A solutionizing process is a physical heat treatment process in which a material is heated to a specific elevated temperature and held there for a sufficient duration to completely dissolve secondary alloying phases or precipitates into the primary solid solution matrix, typically followed by rapid cooling (quenching) to trap those elements in a supersaturated state prior to aging." .


###  https://w3id.org/pmd/cto/CTO_0000013
:CTO_0000013 rdf:type owl:Class ;
             rdfs:label "stress rupture time"@en ;
             skos:definition "A stress rupture time is a temporal interval that specifies the duration from the application of stress to the occurrence of rupture in a material." .


###  https://w3id.org/pmd/cto/CTO_0000014
:CTO_0000014 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000052 ;
                               owl:someValuesFrom :CTO_0000008
                             ] ;
             rdfs:label "stress exponent"@en ;
             skos:definition "A stress exponent is a mechanical property that characterizes the sensitivity of creep rate to applied stress, typically appearing as an exponent in creep rate equations." .


###  https://w3id.org/pmd/cto/CTO_0000015
:CTO_0000015 rdf:type owl:Class ;
             rdfs:label "precipitate"@en ;
             skos:definition "A precipitate is an object that is a distinct solid phase formed within a material, typically by separation from a solution or matrix." .


###  https://w3id.org/pmd/cto/CTO_0000016
:CTO_0000016 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000015 ;
             rdfs:label "delta pricipitate"@en ;
             skos:definition "A delta precipitate is a precipitate that is a specific phase (typically δ-phase) formed within a material under particular thermodynamic and processing conditions." .


###  https://w3id.org/pmd/cto/CTO_0000017
:CTO_0000017 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000015 ;
             rdfs:label "gamma pricipitate"@en ;
             skos:definition "A gamma precipitate is a precipitate that is a γ-phase formed within a material, typically contributing to its mechanical properties." .


###  https://w3id.org/pmd/cto/CTO_0000018
:CTO_0000018 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_0000015 ;
             rdfs:label "gamma prime pricipitate"@en ;
             skos:definition "A gamma prime precipitate is a precipitate that is a γ′-phase formed within a material, typically strengthening it by hindering dislocation motion." .


###  https://w3id.org/pmd/cto/CTO_0000021
:CTO_0000021 rdf:type owl:Class ;
             rdfs:label "creep material identifier"@en ;
             skos:definition "A creep material identifier is a material identifier that denotes a creep test piece which participates in a creep testing process. It uniquely identifies the material used in a creep experiment by specifying its string name, like \"Inconel 625\". typically found in the materials section, specimen description, or experimental setup of a scientific paper, and explicitly refers to the material of the target creep test piece" .


###  https://w3id.org/pmd/cto/CTO_0000022
:CTO_0000022 rdf:type owl:Class ;
             rdfs:label "creep test piece chemical composition"@en ;
             skos:definition "creep test piece composition is a chemical composition data item that is specification of the chemical composition of a creep test piece which participates in a creep testing process. It is an information content entity about the elemental makeup of the material, specifying the proportions of chemical elements present. It appears as a table of element symbols with corresponding weight percent (wt.%) or atomic percent (at.%) values, or as inline compositional text, typically found in the materials section or a dedicated composition table of a scientific paper, and explicitly refers to the chemical makeup of the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_0000023
:CTO_0000023 rdf:type owl:Class ;
             rdfs:label "creep test piece grain size value"@en ;
             skos:definition "A creep test piece grain size value is a scalar value specification that specifies the value of the grain size of a crystallite which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the average or representative grain dimension of the material microstructure. It appears as a numeric value with a length unit (e.g., \"170 μm\", \"80–190 μm\"), typically found in the microstructure characterization section, results table, or specimen description of a scientific paper, and explicitly refers to the grain size of the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_0000024
:CTO_0000024 rdf:type owl:Class ;
             rdfs:label "creep test standard"@en ;
             skos:definition "A creep test standard is a standard that is concretized as a plan which is intended to realize a creep testing process. It establishes the set of guidelines, criteria, and norms governing the execution of a creep test. It appears as a designator string referencing an internationally recognized testing norm (e.g., \"ASTM E139\", \"ASTM E 8M-94a\", \"ISO 204\"), typically found in the experimental methods, testing conditions, or specimen preparation section of a scientific paper, and explicitly refers to the normative framework under which the target creep test was conducted." .


###  https://w3id.org/pmd/cto/CTO_0000025
:CTO_0000025 rdf:type owl:Class ;
             rdfs:label "specified creep temperature datum"@en ;
             skos:definition "A specified creep temperature datum is an input specification that is concretized as a temperature which changes a quality in a creep testing process. It prescribes the test temperature applied as a controlled input condition during the creep experiment. It appears as a numeric value with a temperature unit (e.g., \"650°C\", \"750 K\"), typically found in the testing parameters table, experimental conditions section, or figure axes of a scientific paper, and explicitly refers to the temperature at which the target creep test was conducted." .


###  https://w3id.org/pmd/cto/CTO_0000026
:CTO_0000026 rdf:type owl:Class ;
             rdfs:label "specified creep stress datum"@en ;
             skos:definition "A specified creep stress datum is an input specification that is concretized as a mechanical stress which is realized in a creep testing process. It prescribes the applied stress imposed on the creep test piece as the primary loading input. It appears as a numeric value with a stress unit (e.g., \"625 MPa\", \"150 MPa\"), typically found in the testing parameters table, experimental conditions section, or figure axes of a scientific paper, and explicitly refers to the initial applied stress under which the target creep test was conducted." .


###  https://w3id.org/pmd/cto/CTO_0000027
:CTO_0000027 rdf:type owl:Class ;
             rdfs:label "creep rupture time value"@en ;
             skos:definition "A creep rupture time value is a scalar value specification that specifies the value of the stress rupture time of a loading process which is part of a creep testing process. It quantifies the total duration from the application of load to specimen fracture. It appears as a numeric value with a time unit (e.g., \"159.74 h\", \"68779 h\"), typically found in the creep properties table, results section, or Larson–Miller plots of a scientific paper, and explicitly refers to the time to rupture of the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_0000028
:CTO_0000028 rdf:type owl:Class ;
             rdfs:label "creep percentage permanent elongation value"@en ;
             skos:definition "A creep percentage permanent elongation value is a scalar value specification that specifies the value of the percentage permanent elongation realized in a creep testing process. It quantifies the irreversible axial deformation of the specimen after unloading relative to its original gauge length. It appears as a numeric value expressed as a percentage (e.g., \"13.8%\"), typically found in the creep properties table or post-test characterization section of a scientific paper, and explicitly refers to the permanent elongation measured on the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_0000029
:CTO_0000029 rdf:type owl:Class ;
             rdfs:label "Percentage elongation after creep fracture value"@en ;
             skos:definition "A percentage elongation after creep fracture value is a scalar value specification that specifies the value of the percentage elongation after creep fracture realized in a creep testing process. It quantifies the total axial elongation of the specimen measured after fracture relative to its original gauge length. It appears as a numeric value expressed as a percentage, typically found in the creep properties table or post-fracture measurement section of a scientific paper, and explicitly refers to the elongation measured on the fractured creep test piece." .


###  https://w3id.org/pmd/cto/CTO_0000030
:CTO_0000030 rdf:type owl:Class ;
             rdfs:label "percentage reduction of area after creep fracture value"@en ;
             skos:definition "A percentage reduction of area after creep fracture value is a scalar value specification that specifies the value of the percentage reduction of area after creep fracture realized in a creep testing process. It quantifies the cross-sectional area decrease at the fracture location relative to the original cross-sectional area. It appears as a numeric value expressed as a percentage, typically found in the creep properties table or post-fracture measurement section of a scientific paper, and explicitly refers to the area reduction measured at the fracture zone of the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_0000031
:CTO_0000031 rdf:type owl:Class ;
             rdfs:label "percentage total extension value"@en ;
             skos:definition "A percentage total extension value is a scalar value specification that specifies the value of the percentage total extension realized in a creep testing process. It quantifies the total deformation of the specimen accumulated throughout the entire creep test relative to the original gauge length. It appears as a numeric value expressed as a percentage, typically found in the creep properties or deformation data table of a scientific paper, and explicitly refers to the total extension recorded during the target creep test." .


###  https://w3id.org/pmd/cto/CTO_0000033
:CTO_0000033 rdf:type owl:Class ;
             rdfs:label "percentage elastic extension value"@en ;
             skos:definition "A percentage elastic extension value is a scalar value specification that specifies the value of the percentage elastic extension realized in a creep testing process. It quantifies the recoverable deformation component of the specimen upon loading, relative to the original gauge length. It appears as a numeric value expressed as a percentage, typically found in the creep deformation breakdown table of a scientific paper, and explicitly refers to the elastic extension component recorded during the target creep test." .


###  https://w3id.org/pmd/cto/CTO_0000034
:CTO_0000034 rdf:type owl:Class ;
             rdfs:label "percentage initial plastic extension value"@en ;
             skos:definition "A percentage initial plastic extension value is a scalar value specification that specifies the value of the percentage initial plastic extension realized in a creep testing process. It quantifies the irreversible deformation occurring immediately upon load application before the creep stage, relative to the original gauge length. It appears as a numeric value expressed as a percentage, typically found in the creep deformation breakdown table of a scientific paper, and explicitly refers to the initial plastic extension at the onset of the target creep test." .


###  https://w3id.org/pmd/cto/CTO_0000035
:CTO_0000035 rdf:type owl:Class ;
             rdfs:label "percentage plastic extension value"@en ;
             skos:definition "A percentage plastic extension value is a scalar value specification that specifies the value of the percentage plastic extension realized in a creep testing process. It quantifies the total irreversible deformation of the specimen accumulated during the creep test, relative to the original gauge length. It appears as a numeric value expressed as a percentage, typically found in the creep deformation data table of a scientific paper, and explicitly refers to the plastic extension component recorded during the target creep test." .


###  https://w3id.org/pmd/cto/CTO_0000036
:CTO_0000036 rdf:type owl:Class ;
             rdfs:label "percentage creep extension value"@en ;
             skos:definition "A percentage creep extension value is a scalar value specification that specifies the value of the percentage creep extension realized in a creep testing process. It quantifies the time-dependent deformation of the specimen that occurs specifically under sustained load at elevated temperature, relative to the original gauge length. It appears as a numeric value expressed as a percentage, typically found in the creep strain or creep deformation table of a scientific paper, and explicitly refers to the creep-specific extension accumulated during the target creep test" .


###  https://w3id.org/pmd/cto/CTO_0000037
:CTO_0000037 rdf:type owl:Class ;
             rdfs:label "stady state creep rate value"@en ;
             skos:definition "steady state creep rate value is a scalar value specification that specifies the value of the creep rate which is a process attribute of a creep testing process. It quantifies the minimum or steady-state strain rate at which the specimen deforms during the secondary creep stage. It appears as a numeric value with a unit of inverse time (e.g., \"0.96 × 10⁻⁴ s⁻¹\", \"1.04 × 10⁻⁴ 1/s\"), typically found in the creep properties table, results section, or Norton power-law fitting data of a scientific paper, and explicitly refers to the steady-state creep rate measured during the target creep test." .


###  https://w3id.org/pmd/cto/CTO_0000038
:CTO_0000038 rdf:type owl:Class ;
             rdfs:label "stress exponent value"@en ;
             skos:definition "A stress exponent value is a scalar value specification that specifies the value of the stress exponent realized in a creep testing process. It quantifies the sensitivity of the creep rate to applied stress, as defined by the Norton power-law creep model (ε̇ ∝ σⁿ). It appears as a dimensionless numeric value (e.g., \"n = 5\", \"n = 10\"), typically found in the creep analysis, model fitting, or discussion section of a scientific paper, and explicitly refers to the stress exponent derived from the target creep testing data." .


###  https://w3id.org/pmd/cto/CTO_0000039
:CTO_0000039 rdf:type owl:Class ;
             rdfs:label "creep activation energy value"@en ;
             skos:definition "A creep activation energy value is a scalar value specification that specifies the value of the activation energy which is a process attribute of a creep testing process. It quantifies the energy barrier governing thermally activated creep deformation mechanisms, commonly derived from Arrhenius-type analysis. It appears as a numeric value with a unit of energy per mole (e.g., \"276 kJ/mol\", \"309 kJ/mol\"), typically found in the creep analysis, Arrhenius plot, or discussion section of a scientific paper, and explicitly refers to the activation energy characterizing the dominant creep mechanism in the target creep testing process." .


###  https://w3id.org/pmd/cto/CTO_1000000
:CTO_1000000 rdf:type owl:Class ;
             rdfs:label "creep publication DOI"@en ;
             skos:definition "A creep publication DOI is a Digital Object Identifier (DOI) that denotes a publication which is about a creep testing process. It uniquely and persistently identifies a publication reporting on a creep testing process. It appears as a string in the format 10.XXXX/XXXXX, typically found in the header sections of the first page, and explicitly refers to the target creep publication." .


###  https://w3id.org/pmd/cto/CTO_1000001
:CTO_1000001 rdf:type owl:Class ;
             obo:IAO_0000119 "https://www.iso.org/standard/67737.html" ;
             rdfs:label "creep test machine heating system"@en ;
             skos:definition "The heating device provided for heating the test piece to the prescribed temperature (T)." .


###  https://w3id.org/pmd/cto/CTO_1000002
:CTO_1000002 rdf:type owl:Class ;
             obo:IAO_0000119 "https://www.iso.org/standard/41931.html" ;
             rdfs:label "creep test machine loading sensor"@en ;
             skos:definition "The force transducer used to measure the applied load, verified to ISO 7500-2, Class 1 or better." .


###  https://w3id.org/pmd/cto/CTO_1000004
:CTO_1000004 rdf:type owl:Class ;
             rdfs:label "creep test piece identifier"@en ;
             skos:definition "A creep test piece identifier is an object identifier that denotes a creep test piece which participates in a creep testing process. It uniquely designates a specific specimen used in a creep experiment. It appears as an alphanumeric code, label, or sample name (e.g., \"HT1\", \"SSM_100\", \"CLH4663\"), typically found in the specimen description, experimental setup table, or results section of a scientific paper, and explicitly refers to the individual creep test piece under investigation." .


###  https://w3id.org/pmd/cto/CTO_1000005
:CTO_1000005 rdf:type owl:Class ;
             rdfs:label "creep test piece manufacturing description"@en ;
             skos:definition "A creep test piece manufacturing description is a textual description that denotes a manufacturing process which performed for preparing the sample before creep testing process. It describes the fabrication route applied to produce the creep test piece prior to testing. It appears as a text string or structured narrative describing methods such as casting, forging, additive manufacturing, or powder metallurgy (e.g., \"LPBF (EOSINT M290) + HIP\", \"VIM + ESR\"), typically found in the materials and methods section or specimen preparation section of a scientific paper, and explicitly refers to the manufacturing history of the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000006
:CTO_1000006 rdf:type owl:Class ;
             rdfs:subClassOf :CTO_1000005 ;
             rdfs:label "creep test piece solutionizing description"@en ;
             skos:definition "A creep test piece solutionizing description is a textual description that denotes a solutionizing heat treatment process which perfomed before creep testing process. It describes the high-temperature homogenization treatment applied to the creep test piece before testing. It appears as a text string specifying temperature, duration, and cooling method (e.g., \"1095°C, 1 h/AC\", \"HIP: 100 MPa, 1175°C, 4 h\"), typically found in the heat treatment, specimen preparation, or materials section of a scientific paper, and explicitly refers to the solutionizing step applied to the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000007
:CTO_1000007 rdf:type owl:Class ;
             rdfs:label "creep test piece aging description"@en ;
             skos:definition "A creep test piece aging description is a textual description that denotes an aging process which performed before creep testing process. It describes the precipitation hardening or aging heat treatment applied to the creep test piece prior to testing. It appears as a text string specifying temperature, duration, cooling rate, and number of steps (e.g., \"720°C, 8 h/FC 57 K/h to 620°C, 8 h/AC\"), typically found in the heat treatment or specimen preparation section of a scientific paper, and explicitly refers to the aging treatment applied to the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000009
:CTO_1000009 rdf:type owl:Class ;
             rdfs:label "data acquisition system"@en ;
             skos:definition "The central unit collecting signals from load cells, extensometers, and thermocouples." .


###  https://w3id.org/pmd/cto/CTO_1000010
:CTO_1000010 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000081 ;
                               owl:someValuesFrom :CTO_0000008
                             ] ;
             rdfs:label "creep test piece role"@en ;
             skos:definition "The realizable entity that the specimen plays during the experiment (i.e., being the object under stress)." .


###  https://w3id.org/pmd/cto/CTO_1000011
:CTO_1000011 rdf:type owl:Class ;
             rdfs:label "creep test piece delta precipitate fraction value"@en ;
             skos:definition "A creep test piece delta precipitate fraction value is a scalar value specification that specifies the value of the volume proportion of delta precipitate which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the relative volumetric abundance of delta phase in the material. It appears as a numeric value expressed as a percentage or fraction (e.g., \"5 vol%\", \"0.03\"), typically found in the microstructure characterization or phase analysis section of a scientific paper, and explicitly refers to the delta precipitate fraction in the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000012
:CTO_1000012 rdf:type owl:Class ;
             rdfs:label "creep test piece delta precipitate size value"@en ;
             skos:definition "A creep test piece delta precipitate size value is a scalar value specification that specifies the value of the size of a delta precipitate which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the average or representative dimension of delta phase particles in the material. It appears as a numeric value with a length unit (e.g., \"2 μm\", \"500 nm\"), typically found in the microstructure characterization or TEM/SEM analysis section of a scientific paper, and explicitly refers to the delta precipitate size in the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000021
:CTO_1000021 rdf:type owl:Class ;
             rdfs:label "creep test piece gamma precipitate fraction value"@en ;
             skos:definition "A creep test piece gamma precipitate fraction value is a scalar value specification that specifies the value of the volume proportion of gamma precipitate which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the relative volumetric abundance of the gamma phase in the material. It appears as a numeric value expressed as a percentage or fraction (e.g., \"20 vol%\"), typically found in the microstructure characterization or phase analysis section of a scientific paper, and explicitly refers to the gamma precipitate fraction in the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000022
:CTO_1000022 rdf:type owl:Class ;
             rdfs:label "creep test piece gamma precipitate size value"@en ;
             skos:definition "A creep test piece gamma precipitate size value is a scalar value specification that specifies the value of the size of a gamma precipitate which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the average or representative dimension of gamma phase particles in the material. It appears as a numeric value with a length unit (e.g., \"50 nm\", \"0.5 μm\"), typically found in the microstructure characterization or phase analysis section of a scientific paper, and explicitly refers to the gamma precipitate size in the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000023
:CTO_1000023 rdf:type owl:Class ;
             rdfs:label "creep test piece gamma prime precipitate fraction value"@en ;
             skos:definition "A creep test piece gamma prime precipitate fraction value is a scalar value specification that specifies the value of the volume proportion of gamma prime precipitate which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the relative volumetric abundance of the gamma prime strengthening phase in the material. It appears as a numeric value expressed as a percentage or fraction (e.g., \"15–25 vol%\"), typically found in the microstructure characterization, phase analysis, or materials section of a scientific paper, and explicitly refers to the gamma prime precipitate fraction in the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000024
:CTO_1000024 rdf:type owl:Class ;
             rdfs:label "creep test piece gamma prime precipitate size value"@en ;
             skos:definition "A creep test piece gamma prime precipitate size value is a scalar value specification that specifies the value of the size of a gamma prime precipitate which is a member of a microstructure that is part of a creep test piece participating in a creep testing process. It quantifies the average or representative dimension of gamma prime phase particles in the material. It appears as a numeric value with a length unit (e.g., \"100 nm\", \"0.2 μm\"), typically found in the microstructure characterization or TEM analysis section of a scientific paper, and explicitly refers to the gamma prime precipitate size in the target creep test piece." .


###  https://w3id.org/pmd/cto/CTO_1000025
:CTO_1000025 rdf:type owl:Class ;
             rdfs:label "percentage initial total extension value"@en ;
             skos:definition "A percentage initial total extension value is a scalar value specification that specifies the value of the percentage initial total extension realized in a creep testing process. It quantifies the total deformation recorded at the onset of loading before the creep stage begins, relative to the original gauge length. It appears as a numeric value expressed as a percentage, typically found in the creep deformation table or initial loading data section of a scientific paper, and explicitly refers to the initial total extension at the start of the target creep test." .


###  https://w3id.org/pmd/cto/CTO_1000027
:CTO_1000027 rdf:type owl:Class ;
             rdfs:label "reference length to calculate percentage elongation"@en ;
             skos:definition "The standard length used for the calculation of ductility (elongation) at the end of the test, often defined by standards relative to the diameter (e.g., $5d$)." .


###  https://w3id.org/pmd/cto/CTO_1000028
:CTO_1000028 rdf:type owl:Class ;
             rdfs:label "reference length to calculate percentage extension"@en ;
             skos:definition "The length used to calculate non-proportional extension, often distinct from elongation in specific creep contexts involving plastic deformation." .


###  https://w3id.org/pmd/cto/CTO_1000032
:CTO_1000032 rdf:type owl:Class ;
             rdfs:label "test piece origin"@en ;
             skos:definition "A test piece origin is a 3D spatial region that specifies the spatial location from an object from which a test piece is taken." .


###  https://w3id.org/pmd/cto/CTO_1000033
:CTO_1000033 rdf:type owl:Class ;
             rdfs:label "creep testing machine role"@en ;
             skos:definition "The function realized by the testing equipment when it is used to perform a creep test." .


###  https://w3id.org/pmd/cto/CTO_1000035
:CTO_1000035 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/pmd/co/PMD_0020127> ;
                               owl:someValuesFrom :CTO_0000014
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/pmd/co/PMD_0020127> ;
                               owl:someValuesFrom :CTO_1000304
                             ] ;
             obo:IAO_0000119 "https://www.iso.org/standard/67737.html" ;
             rdfs:label "creep rate"@en ;
             skos:definition "The speed at which creep strain develops during a creep test." .


###  https://w3id.org/pmd/cto/CTO_1000036
:CTO_1000036 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/pmd/co/PMD_0000004> ;
                               owl:someValuesFrom :CTO_1000048
                             ] ;
             obo:IAO_0000119 "https://www.iso.org/standard/67737.html" ;
             rdfs:label "primary creep region" ;
             skos:definition "The stage of creep characterized by a decreasing creep rate as material hardening occurs." .


###  https://w3id.org/pmd/cto/CTO_1000037
:CTO_1000037 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/pmd/co/PMD_0000004> ;
                               owl:someValuesFrom :CTO_1000048
                             ] ;
             obo:IAO_0000119 "https://www.iso.org/standard/67737.html" ;
             rdfs:label "secondary creep region"@en ;
             skos:definition "The stage of creep where the creep rate becomes nearly constant and steady-state deformation dominates." .


###  https://w3id.org/pmd/cto/CTO_1000038
:CTO_1000038 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/pmd/co/PMD_0000004> ;
                               owl:someValuesFrom :CTO_1000048
                             ] ;
             obo:IAO_0000119 "https://www.iso.org/standard/67737.html" ;
             rdfs:label "tertiary creep region"@en ;
             skos:definition "The final creep stage marked by accelerated creep rate leading to material failure." .


###  https://w3id.org/pmd/cto/CTO_1000039
:CTO_1000039 rdf:type owl:Class ;
             rdfs:subClassOf [ owl:intersectionOf ( :CTO_1000304
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:RO_0000052 ;
                                                      owl:someValuesFrom :CTO_0000008
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             obo:IAO_0000119 "https://w3id.org/pmd/co/Stress" ;
             rdfs:label "creep threshold stress"@en ;
             skos:definition "The theoretical lower limiting stress below which no measurable creep deformation occurs." .


###  https://w3id.org/pmd/cto/CTO_1000040
:CTO_1000040 rdf:type owl:Class ;
             rdfs:label "creep activation energy"@en ;
             skos:definition "The thermal energy barrier (Qc​) required to initiate the dominant creep mechanism (related to diffusion)." .


###  https://w3id.org/pmd/cto/CTO_1000041
:CTO_1000041 rdf:type owl:Class ;
             rdfs:subClassOf [ owl:intersectionOf ( :CTO_1000304
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty obo:RO_0000052 ;
                                                      owl:someValuesFrom :CTO_0000008
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             obo:IAO_0000119 "https://www.iso.org/standard/67737.html" ;
             rdfs:label "creep rupture stress"@en ;
             skos:definition "The stress capable of causing fracture at a specific time and temperature." .


###  https://w3id.org/pmd/cto/CTO_1000042
:CTO_1000042 rdf:type owl:Class ;
             rdfs:label "grain boundary creep mechanism"@en ;
             skos:definition "Deformation caused by the sliding of grains past one another (often Coble creep)." .


###  https://w3id.org/pmd/cto/CTO_1000043
:CTO_1000043 rdf:type owl:Class ;
             rdfs:label "dislocation creep mechanism" ;
             skos:definition "Deformation caused by the movement (climb/glide) of dislocations through the crystal lattice (Power-law creep)." .


###  https://w3id.org/pmd/cto/CTO_1000044
:CTO_1000044 rdf:type owl:Class ;
             rdfs:label "diffusional creep mechanism" ;
             skos:definition "Deformation caused by the stress-directed diffusion of vacancies (Nabarro-Herring creep)." .


###  https://w3id.org/pmd/cto/CTO_1000045
:CTO_1000045 rdf:type owl:Class ;
             rdfs:label "steady-state creep rate equation"@en ;
             skos:comment "A steady-state creep rate equation is an equation textual entity that expresses the constant creep rate of a material during the steady-state (secondary) creep regime as a function of variables such as stress and temperature." ;
             skos:definition "The mathematical formula describing the secondary creep rate (e.g., Norton's Law)." .


###  https://w3id.org/pmd/cto/CTO_1000046
:CTO_1000046 rdf:type owl:Class ;
             obo:IAO_0000119 "https://www.iso.org/standard/67737.html" ;
             rdfs:label "creep test uncertainty" ;
             skos:definition "The estimated range of values within which the true value of the measurement lies (ISO 204 Annex E)." .


###  https://w3id.org/pmd/cto/CTO_1000047
:CTO_1000047 rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty obo:RO_0000052 ;
                               owl:someValuesFrom :CTO_0000008
                             ] ;
             rdfs:label "creep modulus"@en ;
             skos:definition "The secant modulus defined as the ratio of initial stress to the creep strain at a given time (Ec​=σ/εc​)." .


###  https://w3id.org/pmd/cto/CTO_1000048
:CTO_1000048 rdf:type owl:Class ;
             rdfs:label "creep curve"@en ;
             skos:definition "The graphical or tabular representation of strain (ε) versus time (t) for a specific test." .


###  https://w3id.org/pmd/cto/CTO_1000049
:CTO_1000049 rdf:type owl:Class ;
             terms:source "https://www.iso.org/standard/67737.html" ;
